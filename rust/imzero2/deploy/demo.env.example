# Copy to demo.env and fill in. Named demo.env (not .env) on purpose so Docker
# Compose does NOT auto-interpolate it — the bcrypt hash's '$' pass through
# literally, no escaping needed.

# Public hostname that resolves to the box. Either a (sub)domain you point at
# the box, or the zero-setup trick: <box-ip>.nip.io  (e.g. 203.0.113.7.nip.io).
DOMAIN=REPLACE.with-your-domain-or-ip.nip.io

# Password gate (Caddy basic_auth).
BASIC_AUTH_USER=demo
# Generate the hash (keep the single quotes):
#   docker run --rm caddy:2 caddy hash-password --plaintext 'YOUR_PASSWORD'
BASIC_AUTH_HASH=REPLACE_WITH_BCRYPT_HASH

# Which demo to auto-open. Leave EMPTY for the lean interactive carousel — the
# viewer opens any demo (sccmap, widgets, leewaywidgets, idsshowcase, sccmap,
# hn_explorer, logdemo, regex_explorer, registry) from the launcher in-browser.
# Auto-opening a specific demo resolves via clickhouse-local, which is NOT in
# the default image (it would add ~2 GB) — see DEPLOY.md for that variant.
#   LAUNCH=sccmap     # only works with the clickhouse-local image variant
LAUNCH=

# Software H.264 encoder (no GPU on the VPS). Default is x264; for the
# ADR-verified frame-stable path use libopenh264 instead:
#   IMZERO2_HEADLESS_ENCODER_ARGS=-c:v libopenh264 -b:v 4M -bf 0 -g 60
IMZERO2_HEADLESS_ENCODER_ARGS=-c:v libx264 -preset veryfast -tune zerolatency -bf 0 -g 100000

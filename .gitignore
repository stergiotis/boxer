# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Compiled Go command binaries built at repo root (extensionless on Linux, so
# the *.exe/*.so patterns above don't catch them — listed explicitly, anchored
# so identically-named subdirs/packages are unaffected).
/app
/boxer
/envgen
/imzero2
/licensegate

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work

# goland files
.idea

# Local analysis outputs at repo root (anchored so subdirs are unaffected).
/report.md
/summary.md
/assessment.gen.md
/out.json
/results.json

# Rust build artifacts — cargo target directories under rust/<crate>/target.
rust/*/target/

# boxer adr tool cache — the `boxer adr build` default --out dir. It can be
# created in any working directory (the command takes --root), so not anchored.
.adrcache/

# Local Claude Code settings (machine-specific); the .claude/skills symlink stays tracked.
.claude/settings.local.json
.claude/scheduled_tasks.lock
